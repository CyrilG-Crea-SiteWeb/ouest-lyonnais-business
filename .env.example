# Modèle de configuration — copiez ce fichier en `.env` et renseignez vos valeurs.
# Ne committez JAMAIS le vrai `.env` (il est ignoré par git).
#
# Ces clés "publishable" (anon) sont publiques par nature. La clé de service
# (SUPABASE_SERVICE_ROLE_KEY) ne doit JAMAIS figurer ici : elle reste dans les
# secrets Lovable Cloud, côté serveur uniquement.

SUPABASE_PROJECT_ID="votre-project-id"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_URL="https://votre-project-id.supabase.co"

VITE_SUPABASE_PROJECT_ID="votre-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_URL="https://votre-project-id.supabase.co"
